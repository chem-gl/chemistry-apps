# .env.example: Variables de entorno de ejemplo para backend local.
# Copia este archivo a .env y ajusta valores según tu entorno.

DJANGO_SECRET_KEY=replace-with-a-secure-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# CORS para frontend local Angular.
ENABLE_CORS=True
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Celery + Redis local.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Recuperación activa de jobs tras reinicios/caídas.
JOB_RECOVERY_ENABLED=True
JOB_RECOVERY_STALE_SECONDS=60
JOB_RECOVERY_MAX_ATTEMPTS=5
JOB_RECOVERY_INCLUDE_PENDING=True

# Motor de base de datos (sqlite por defecto en local).
DB_ENGINE=sqlite
# Ruta opcional para sqlite (util en Docker con volumen persistente).
# DB_SQLITE_PATH=/data/db.sqlite3

# ---------------------------------------------------------------------------
# Política de retención de artefactos (archivos subidos por el usuario).
#
# ARTIFACT_INLINE_THRESHOLD_KB:
#   Umbral en KB. Archivos <= este tamaño se guardan PERMANENTEMENTE en DB.
#   Por defecto: 250 (= 0.25 MB).
#   Ejemplo para cambiar a 500 KB: ARTIFACT_INLINE_THRESHOLD_KB=500
#
# ARTIFACT_LARGE_FILE_TTL_DAYS:
#   Días que se conservan los binarios de archivos que superan el umbral.
#   Después de este tiempo la tarea diaria borra los chunks binarios PERO
#   conserva metadatos (sha256, tamaño, nombre) y el resultado calculado.
#   Por defecto: 30 (1 mes).
#   Ejemplo para 90 días: ARTIFACT_LARGE_FILE_TTL_DAYS=90
# ---------------------------------------------------------------------------
ARTIFACT_INLINE_THRESHOLD_KB=250
ARTIFACT_LARGE_FILE_TTL_DAYS=30
