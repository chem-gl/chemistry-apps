# .env.example: Variables de entorno de ejemplo para backend local.
# Copia este archivo a .env y ajusta valores según tu entorno.

DJANGO_SECRET_KEY=replace-with-a-secure-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# CORS para frontend local Angular.
ENABLE_CORS=True
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# Celery + Redis local.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Recuperación activa de jobs tras reinicios/caídas.
JOB_RECOVERY_ENABLED=True
JOB_RECOVERY_STALE_SECONDS=60
JOB_RECOVERY_MAX_ATTEMPTS=5
JOB_RECOVERY_INCLUDE_PENDING=True

# Motor de base de datos (sqlite por defecto en local).
DB_ENGINE=sqlite
