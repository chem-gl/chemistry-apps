{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --host 0.0.0.0 --port 4200",
    "build": "ng build",
    "lint": "eslint .",
    "lint:sonar": "eslint . -f json -o eslint.json",
    "test:coverage:ci": "ng test --watch=false --coverage",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "api:generate": "openapi-generator generate -i ../backend/openapi/schema.yaml -g typescript-angular -o src/app/core/api/generated --additional-properties=ngVersion=21,supportsES6=true,withInterfaces=true && rm -f src/app/core/api/generated/README.md src/app/core/api/generated/git_push.sh",
    "api:generate:local": "cd ../backend && poetry run python manage.py spectacular --file openapi/schema.yaml && cd ../frontend && npm run api:generate"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/build": "^21.2.3",
    "@angular/common": "^21.2.5",
    "@angular/compiler": "^21.2.5",
    "@angular/core": "^21.2.5",
    "@angular/forms": "^21.2.5",
    "@angular/platform-browser": "^21.2.5",
    "@angular/platform-server": "^21.2.5",
    "@angular/router": "^21.2.5",
    "@angular/ssr": "^21.2.3",
    "@jsverse/transloco": "^8.3.0",
    "@types/jszip": "^3.4.0",
    "jszip": "^3.10.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.1"
  },
  "devDependencies": {
    "@angular/cli": "^21.2.3",
    "@angular/compiler-cli": "^21.2.5",
    "@cspell/dict-es-es": "^3.0.8",
    "@eslint/js": "^9.35.0",
    "@openapitools/openapi-generator-cli": "^0.0.6",
    "@vitest/coverage-v8": "^4.1.2",
    "angular-eslint": "^21.0.0",
    "eslint": "^9.35.0",
    "globals": "^16.4.0",
    "jsdom": "^27.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.43.0",
    "vitest": "^4.0.8"
  }
}
